  "keyFeatures": [
    "Real-time search with 500ms debounce for performance optimization",
    "Three data modes: local array, DOM element indexing, and AJAX requests",
    "Built-in pagination with configurable items per page",
    "Unified cache system with 5-minute expiration for both local and server data",
    "Custom item rendering via configurable renderizarItem function",
    "Auto-generated HTML structure when elements are missing",
    "Unique CSS class generation to support multiple instances on the same page",
    "XMLHttpRequest-based AJAX with support for POST, GET, PUT, PATCH methods"
  ],
  "publicApiSurface": [
    "new search(config)",
    "config.element",
    "config.itemsPerPage",
    "config.procesServer",
    "config.data",
    "config.renderizarItem",
    "init()",
    "initializeWithData()",
    "buscarEImprimir(searchTerm)",
    "calcularPaginacion(totalItems)",
    "filtrarDatos(data, searchTerm)",
    "imprimirDatos(data)",
    "renderPagination(totalPages)",
    "renderizarItem(element)",
    "ajax(config)",
    "extraerItemsData()"
  ]
}
